# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Build artifacts
*.out
coverage.*
dist/
# Keep the embed-anchor .gitkeep visible so `//go:embed all:dist` compiles
# on fresh checkouts before the SPA is built. The SPA build outputs
# themselves stay ignored via the rule pairs below.
!server/chatui/dist/
server/chatui/dist/*
!server/chatui/dist/.gitkeep
!server/workflowui/dist/
server/workflowui/dist/*
!server/workflowui/dist/.gitkeep

# Certificates and keys
*.pem
*.key

# Databases
*.db
*.db-journal
*.db-shm
*.db-wal

# Environment files
.env
.env.local
.env.*.local

# Vendor (if using)
vendor/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Go workspace
# Note: go.work.sum is tracked for reproducible Docker/CI builds

# Test artifacts
.test_*
/dojo
/gateway
workers/telemetry/node_modules/

# Compiled binaries
AgenticGatewayByDojoGenesis
wasm-modules/dip-scorer/dip-scorer

# Wrangler state
workers/telemetry/.wrangler/

# External repo clones
claude-plugins-official/

# Claude workspace state
**/.claude/
cmd/dojo/dojo

